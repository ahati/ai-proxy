{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "sk-cp-dummy",
    "ANTHROPIC_BASE_URL": "http://host.docker.internal:8080",
    "ANTHROPIC_MODEL": "glm-5.1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5.1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "kimi-k2.5",
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "qwen3.6-plus",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "qwen3.6-plus",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION": "qwen3.6-plus - 1m context, efficient",
    "CLAUDE_CODE_EFFORT_LEVEL": "high",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_EXTRA_BODY": "{\"output_config\": null}",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "availableModels": [
    "glm-5.1",
    "glm-5",
    "kimi-k2.5",
    "MiniMax-M2.5",
    "MiniMax-M2.7",
    "qwen3.6-plus"
  ],
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "effortLevel": "high",
  "plansDirectory": "./plans",
  "prefersReducedMotion": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "terminalProgressBarEnabled": false,
  "defaultMode": "bypassPermissions",
  "teammateMode": "in-process"
}
