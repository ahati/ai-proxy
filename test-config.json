{
  "providers": [
    {
      "name": "chutes",
      "endpoints": {
        "openai": "https://llm.chutes.ai/v1/chat/completions",
        "anthropic": "https://claude.chutes.ai/v1/messages"
      },
      "default": "openai",
      "envApiKey": "CHUTES_API_KEY"
    },
    {
      "name": "minimax",
      "endpoints": {
        "openai": "https://api.minimax.io/v1/chat/completions",
        "anthropic": "https://api.minimax.io/anthropic/v1/messages"
      },
      "default": "openai",
      "envApiKey": "MINIMAX_IO_API_KEY"
    },
    {
      "name": "alibaba",
      "endpoints": {
        "openai": "https://coding-intl.dashscope.aliyuncs.com/v1/chat/completions",
        "anthropic": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1/messages"
      },
      "default": "openai",
      "envApiKey": "ALIBABA_API_KEY"
    },
    {
      "name": "z.ai",
      "endpoints": {
        "anthropic": "https://api.z.ai/api/anthropic",
        "openai": "https://api.z.ai/api/coding/paas/v4/chat/completions"
      },
      "default": "openai",
      "envApiKey": "ZAI_API_KEY"
    },
    {
      "name": "openrouter",
      "endpoints": {
        "openai": "https://openrouter.ai/api/v1/chat/completions",
        "anthropic": "https://openrouter.ai/api/v1/messages"
      },
      "default": "openai",
      "apiKey": "${OPENROUTER_API_KEY}"
    },
    {
      "name": "ollama",
      "endpoints": {
        "openai": "http://127.0.0.1:11434/v1/chat/completions"
      },
      "default": "openai",
      "apiKey": "dummy"
    }
  ],
  "models": {
    "moonshotai/Kimi-K2.5-TEE": {
      "provider": "chutes",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "type": "auto",
      "kimi_tool_call_transform": true
    },
    "glm-5.1": {
      "provider": "z.ai",
      "model": "glm-5.1",
      "type": "openai"
    },
    "glm-5-turbo": {
      "provider": "z.ai",
      "model": "glm-5-turbo",
      "type": "openai"
    },
    "glm-5": {
      "provider": "alibaba",
      "model": "glm-5",
      "type": "auto",
      "glm5_tool_call_transform": true
    },
    "kimi-k2.5": {
      "provider": "alibaba",
      "model": "kimi-k2.5",
      "type": "anthropic",
      "kimi_tool_call_transform": true
    },
    "gpt-5.4": {
      "provider": "z.ai",
      "model": "glm-5.1"
    },
    "gpt-5.3-codex": {
      "provider": "z.ai",
      "model": "glm-5.1"
    },
    "gpt-5.1-codex-mini": {
      "provider": "minimax",
      "model": "MiniMax-M2.5",
      "type": "auto",
      "reasoning_split": true
    },
    "gpt-5-mini": {
      "provider": "minimax",
      "model": "MiniMax-M2.7",
      "type": "auto",
      "kimi_tool_call_transform": false,
      "reasoning_split": true
    },
    "MiniMax-M2.7": {
      "provider": "minimax",
      "model": "MiniMax-M2.7",
      "type": "auto",
      "kimi_tool_call_transform": false,
      "reasoning_split": true
    },
    "qwen3-max": {
      "provider": "alibaba",
      "model": "qwen3-max-2026-01-23",
      "type": "auto",
      "kimi_tool_call_transform": false
    },
    "claude-opus-4-6": {
      "provider": "alibaba",
      "model": "glm-5",
      "type": "auto",
      "glm5_tool_call_transform": true
    },
    "claude-opus-4-5": {
      "provider": "alibaba",
      "model": "glm-5",
      "type": "auto",
      "glm5_tool_call_transform": true
    },
    "claude-sonnet-4-6": {
      "provider": "alibaba",
      "model": "kimi-k2.5",
      "type": "anthropic",
      "kimi_tool_call_transform": true
    },
    "claude-sonnet-4-5": {
      "provider": "alibaba",
      "model": "kimi-k2.5",
      "type": "anthropic",
      "kimi_tool_call_transform": true
    },
    "claude-haiku-4.5": {
      "provider": "alibaba",
      "model": "MiniMax-M2.5",
      "type": "auto"
    },
    "claude-haiku-4.6": {
      "provider": "alibaba",
      "model": "MiniMax-M2.5",
      "type": "auto"
    },
    "openrouter/qwen3.6-plus:free": {
      "provider": "openrouter",
      "model": "qwen/qwen3.6-plus:free",
      "type": "auto"
    }
  },
  "fallback": {
    "enabled": true,
    "provider": "alibaba",
    "model": "{model}",
    "type": "auto",
    "kimi_tool_call_transform": false
  },
  "summarizer": {
    "enabled": false,
    "mode": "local",
    "local": {
      "model_path": "../temporary/summarizer/models/Qwen3.5-0.8B-Q4_K_M.gguf",
      "context_size": 2048,
      "threads": 4,
      "max_summary_tokens": 50
    }
  },
  "websearch": {
    "enabled": true,
    "provider": "exa",
    "exa_api_key": "${EXA_API_KEY}",
    "brave_api_key": "${BRAVE_API_KEY}",
    "max_results": 10,
    "timeout": 30
  }
}
