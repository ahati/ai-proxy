{
  "providers": [
    {
      "name": "chutes",
      "endpoints": {
        "openai": "https://llm.chutes.ai/v1/chat/completions",
        "anthropic": "https://claude.chutes.ai/v1/messages"
      },
      "default": "openai",
      "envApiKey": "CHUTES_API_KEY"
    },
    {
      "name": "minimax",
      "endpoints": {
        "openai": "https://api.minimax.io/v1/chat/completions",
        "anthropic": "https://api.minimax.io/anthropic/v1/messages"
      },
      "default": "openai",
      "envApiKey": "MINIMAX_IO_API_KEY"
    },
    {
      "name": "alibaba",
      "endpoints": {
        "openai": "https://coding-intl.dashscope.aliyuncs.com/v1/chat/completions",
        "anthropic": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1/messages"
      },
      "default": "openai",
      "envApiKey": "ALIBABA_API_KEY"
    },
    {
      "name": "z.ai",
      "endpoints": {
        "anthropic": "https://api.z.ai/api/anthropic",
        "openai": "https://api.z.ai/api/coding/paas/v4/chat/completions"
      },
      "default": "openai",
      "envApiKey": "ZAI_API_KEY"
    },
    {
      "name": "openrouter",
      "endpoints": {
        "openai": "https://openrouter.ai/api/v1/chat/completions",
        "anthropic": "https://openrouter.ai/api/v1/messages"
      },
      "default": "openai",
      "apiKey": "${OPENROUTER_API_KEY}"
    },
    {
      "name": "ollama",
      "endpoints": {
        "openai": "http://127.0.0.1:11434/v1/chat/completions"
      },
      "default": "openai",
      "apiKey": "dummy"
    },
    {
      "name": "opencode_go",
      "endpoints": {
        "openai": "https://opencode.ai/zen/go/v1/chat/completions"
      },
      "default": "openai",
      "apiKey": "${OPENCODE_GO_API_KEY}"
    }
  ],
  "models": {
    "moonshotai/Kimi-K2.5-TEE": {
      "provider": "chutes",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "type": "auto",
      "kimi_tool_call_transform": true,
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95
      }
    },
    "glm-5.1": {
      "provider": "z.ai",
      "model": "glm-5.1",
      "type": "openai",
      "sampling_params": {
        "temperature": 0.7,
        "top_p": 0.95
      }
    },
    "glm-5-turbo": {
      "provider": "z.ai",
      "model": "glm-5-turbo",
      "type": "openai",
      "sampling_params": {
        "temperature": 0.7,
        "top_p": 0.95
      }
    },
    "glm-5": {
      "provider": "alibaba",
      "model": "glm-5",
      "type": "auto",
      "glm5_tool_call_transform": true,
      "sampling_params": {
        "temperature": 0.7,
        "top_p": 0.95
      }
    },
    "deepseek-v4-pro": {
      "provider": "opencode_go",
      "model": "deepseek-v4-pro",
      "sampling_params": {
        "temperature": 0.7,
        "top_p": 0.95
      }
    },
    "deepseek-v4-flash": {
      "provider": "opencode_go",
      "model": "deepseek-v4-flash",
      "sampling_params": {
        "temperature": 0.7,
        "top_p": 0.95
      }
    },
    "kimi-k2.6": {
      "provider": "opencode_go",
      "model": "kimi-k2.6",
      "type": "auto",
      "kimi_tool_call_transform": true,
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95
      }
    },
    "kimi-k2.5": {
      "provider": "alibaba",
      "model": "kimi-k2.5",
      "type": "anthropic",
      "kimi_tool_call_transform": true,
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95
      }
    },
    "gpt-5.4": {
      "provider": "z.ai",
      "model": "glm-5.1"
    },
    "gpt-5.3-codex": {
      "provider": "z.ai",
      "model": "glm-5.1"
    },
    "gpt-5.1-codex-mini": {
      "provider": "minimax",
      "model": "MiniMax-M2.5",
      "type": "auto",
      "reasoning_split": true,
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95,
        "top_k": 40
      }
    },
    "gpt-5-mini": {
      "provider": "minimax",
      "model": "MiniMax-M2.7",
      "type": "auto",
      "kimi_tool_call_transform": false,
      "reasoning_split": true,
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95,
        "top_k": 40
      }
    },
    "MiniMax-M2.7": {
      "provider": "opencode_go",
      "model": "MiniMax-M2.7",
      "type": "auto",
      "kimi_tool_call_transform": false,
      "reasoning_split": true,
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95,
        "top_k": 40
      }
    },
    "qwen3-max": {
      "provider": "alibaba",
      "model": "qwen3-max-2026-01-23",
      "type": "auto",
      "kimi_tool_call_transform": false,
      "sampling_params": {
        "temperature": 0.7,
        "top_p": 0.8,
        "top_k": 20
      }
    },
    "claude-opus-4-6": {
      "provider": "alibaba",
      "model": "glm-5",
      "type": "auto",
      "glm5_tool_call_transform": true
    },
    "claude-opus-4-5": {
      "provider": "alibaba",
      "model": "glm-5",
      "type": "auto",
      "glm5_tool_call_transform": true
    },
    "claude-sonnet-4-6": {
      "provider": "alibaba",
      "model": "kimi-k2.5",
      "type": "anthropic",
      "kimi_tool_call_transform": true,
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95
      }
    },
    "claude-sonnet-4-5": {
      "provider": "alibaba",
      "model": "kimi-k2.5",
      "type": "anthropic",
      "kimi_tool_call_transform": true,
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95
      }
    },
    "claude-haiku-4.5": {
      "provider": "alibaba",
      "model": "MiniMax-M2.5",
      "type": "auto",
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95,
        "top_k": 40
      }
    },
    "claude-haiku-4.6": {
      "provider": "alibaba",
      "model": "MiniMax-M2.5",
      "type": "auto",
      "sampling_params": {
        "temperature": 1.0,
        "top_p": 0.95,
        "top_k": 40
      }
    },
    "qwen3.6-plus": {
      "provider": "alibaba",
      "model": "qwen3.6-plus",
      "type": "auto",
      "sampling_params": {
        "temperature": 0.7,
        "top_p": 0.8,
        "top_k": 20
      }
    }
  },
  "fallback": {
    "enabled": true,
    "provider": "alibaba",
    "model": "{model}",
    "type": "auto",
    "kimi_tool_call_transform": false,
    "sampling_params": {
      "override": false,
      "temperature": 0.7,
      "top_p": 0.95
    }
  },
  "summarizer": {
    "enabled": false,
    "mode": "local",
    "local": {
      "model_path": "../temporary/summarizer/models/Qwen3.5-0.8B-Q4_K_M.gguf",
      "context_size": 2048,
      "threads": 4,
      "max_summary_tokens": 50
    }
  },
  "websearch": {
    "enabled": true,
    "provider": "exa",
    "exa_api_key": "${EXA_API_KEY}",
    "brave_api_key": "${BRAVE_API_KEY}",
    "max_results": 10,
    "timeout": 30
  }
}