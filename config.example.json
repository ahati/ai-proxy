{
  "$schema": "./config-schema.json",
  "providers": [
    {
      "name": "kimi-k2",
      "endpoints": {
        "openai": "https://llm.chutes.ai/v1/chat/completions",
        "anthropic": "https://llm.chutes.ai/v1/messages"
      },
      "default": "openai",
      "envApiKey": "CHUTES_API_KEY"
    },
    {
      "name": "alibaba-coding",
      "endpoints": {
        "anthropic": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1/messages"
      },
      "envApiKey": "ALIBABA_ANTHROPIC_API_KEY"
    }
  ],
  "models": {
    "kimi-k2.5": {
      "provider": "kimi-k2",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "type": "auto",
      "kimi_tool_call_transform": true,
      "sampling_params": {
        "temperature": 0.7,
        "top_p": 0.95
      }
    },
    "creative-writer": {
      "provider": "kimi-k2",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "type": "auto",
      "sampling_params": {
        "temperature": 1.2,
        "top_p": 0.9,
        "presence_penalty": 0.5
      }
    },
    "precise-assistant": {
      "provider": "kimi-k2",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "type": "openai",
      "sampling_params": {
        "temperature": 0.0
      }
    },
    "flexible-model": {
      "provider": "kimi-k2",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "type": "auto",
      "sampling_params": {
        "override": false,
        "temperature": 0.7,
        "top_p": 0.95
      }
    },
    "claude-3-opus": {
      "provider": "alibaba-coding",
      "model": "claude-3-opus-20240229",
      "type": "anthropic",
      "kimi_tool_call_transform": false
    }
  },
  "fallback": {
    "enabled": true,
    "provider": "kimi-k2",
    "model": "{model}",
    "type": "auto",
    "kimi_tool_call_transform": true,
    "sampling_params": {
      "temperature": 0.5
    }
  },
  "summarizer": {
    "enabled": false,
    "mode": "local",
    "local": {
      "model_path": "./models/Qwen3.5-0.8B-Q4_K_M.gguf",
      "context_size": 2048,
      "threads": 4,
      "max_summary_tokens": 50
    }
  },
  "responses": {
    "max_context_tokens": 0
  },
  "websearch": {
    "enabled": false,
    "provider": "exa",
    "max_results": 10,
    "timeout": 30
  },
  "memoryLogs": {
    "enabled": true,
    "capacity": 2000
  }
}
